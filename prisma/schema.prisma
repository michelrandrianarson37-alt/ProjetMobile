generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  fullName  String
  email     String   @unique
  password  String
  avatar    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  favorites Favorite[]
  histories RecognitionHistory[]

  @@map("users")
}

model Fruit {
  id             Int      @id @default(autoincrement())
  name           String
  scientificName String?
  description    String?
  imageUrl       String?
  originCountry  String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  nutrition      Nutrition?
  favorites      Favorite[]
  histories      RecognitionHistory[]

  @@map("fruits")
}

model Nutrition {
  id            Int    @id @default(autoincrement())
  fruitId       Int    @unique

  calories      Float?
  proteins      Float?
  carbohydrates Float?
  fats          Float?
  fibers        Float?
  vitaminC      Float?

  createdAt     DateTime @default(now())

  fruit Fruit @relation(fields: [fruitId], references: [id], onDelete: Cascade)

  @@map("nutritional_values")
}

model RecognitionHistory {
  id              Int @id @default(autoincrement())

  userId          Int
  fruitId         Int

  imageUrl        String?
  confidenceScore Float?

  recognizedAt    DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  fruit Fruit @relation(fields: [fruitId], references: [id], onDelete: Cascade)

  @@map("recognition_history")
}

model Favorite {
  id        Int @id @default(autoincrement())

  userId    Int
  fruitId   Int

  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  fruit Fruit @relation(fields: [fruitId], references: [id], onDelete: Cascade)

  @@unique([userId, fruitId])

  @@map("favorites")
}